# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# QUOTEX_API_BASE_URL: The base URL for the Quotex market tick-stream API.
# Example: https://api.mydomain.com
QUOTEX_API_BASE_URL="https://api.mydomain.com"

# SUPABASE_URL: URL to connect to Supabase
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY: Secret Key for admin database access
SUPABASE_SERVICE_ROLE_KEY=
